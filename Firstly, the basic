; --- MAIN PROGRAM ---
main PROC
    mov rcx, 5          ; Put 5 in RCX (Standard 1st argument in Windows)
    
    call SquareIt       ; 1. Pushes the address of the next line (mov [res], rax) 
                        ;    onto the stack, then jumps to 'SquareIt'.

    mov [result], rax   ; 4. Execution resumes here. RAX now contains 25.
    ret                 ; Exit main
